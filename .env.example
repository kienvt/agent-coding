# ─── GitLab ───────────────────────────────────────────────────────
# Can be left empty here — set via Web UI after first start
GITLAB_URL=https://gitlab.company.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_BOT_USERNAME=ai-agent
WEBHOOK_SECRET=your-webhook-secret-here

# ─── Anthropic ────────────────────────────────────────────────────
# Leave empty to use Claude subscription auth (~/.claude OAuth)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Workspace ────────────────────────────────────────────────────
# Absolute path on the host where git repos will be cloned
WORKSPACE_PATH=/home/user/ai-workspace

# ─── Optional ─────────────────────────────────────────────────────
LOG_LEVEL=info
# Override if Claude auth is stored somewhere other than ~/.claude
# CLAUDE_AUTH_DIR=/home/user/.claude
